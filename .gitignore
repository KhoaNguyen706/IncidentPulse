# application.yml and application-{dev,prod,test}.yml are committed: they contain
# only ${ENV_VAR} placeholders, never secrets. Real secrets come from env vars.
# Keep any machine-local override out of git:
application-local.yml
/src/main/resources/application-local.yml

# Ignore application.properties (use YAML instead)
application.properties
/src/main/resources/application.properties

