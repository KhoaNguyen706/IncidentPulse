# Example application.yml - copy to application.yml and fill in real values.
# DO NOT commit secrets. Every field below can be overridden by environment
# variables (Spring's relaxed binding converts e.g. JWT_SECRET -> security.jwt.secretBase64).

server:
  port: ${SERVER_PORT:8080}

spring:
  application:
    name: Incident Pulse
  datasource:
    url: ${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/incidentpulse}
    username: ${SPRING_DATASOURCE_USERNAME:postgres}
    password: ${SPRING_DATASOURCE_PASSWORD:postgres}
    driver-class-name: org.postgresql.Driver
  jpa:
    hibernate:
      # dev: update | prod: validate (and use Flyway/Liquibase for migrations)
      ddl-auto: ${SPRING_JPA_DDL_AUTO:update}
    show-sql: ${SPRING_JPA_SHOW_SQL:false}
  mail:
    host: ${MAIL_HOST:smtp.gmail.com}
    port: ${MAIL_PORT:587}
    username: ${MAIL_USERNAME:}
    password: ${MAIL_PASSWORD:}
    properties:
      mail:
        smtp:
          auth: true
          starttls:
            enable: true

# Actuator - expose only what you need in production
management:
  endpoints:
    web:
      exposure:
        include: health,info

app:
  email:
    # Fallback recipient when an incident has no assignee email.
    default-recipient: ${APP_EMAIL_DEFAULT_RECIPIENT:}
  admin:
    # Seeded only when no user with this username exists yet.
    username: ${APP_ADMIN_USERNAME:admin}
    email: ${APP_ADMIN_EMAIL:admin@incidentpulse.local}
    password: ${APP_ADMIN_PASSWORD:admin123}

auth:
  refresh:
    days: ${AUTH_REFRESH_DAYS:14}

security:
  jwt:
    # Generate with: openssl rand -base64 32
    secretBase64: ${JWT_SECRET:CHANGE_ME_BASE64_AT_LEAST_32_BYTES_CHANGE_ME}
    issuer: ${JWT_ISSUER:incidentpulse}
    audience: ${JWT_AUDIENCE:incidentpulse-api}
    accessTokenMinutes: ${JWT_ACCESS_MINUTES:15}
