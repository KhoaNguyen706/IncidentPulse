# Copy to .env and fill in real values:  cp .env.example .env
# .env is gitignored. NEVER commit real secrets.

# --- Active profile -------------------------------------------------------
SPRING_PROFILES_ACTIVE=prod

# --- Database (used by both the Postgres container and the app) -----------
POSTGRES_DB=incidentpulse
POSTGRES_USER=postgres
# Strong password required (the prod compose refuses to start without it):
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Redis ----------------------------------------------------------------
# Inside docker-compose this is the service name; leave as-is for the prod stack.
REDIS_HOST=redis
REDIS_PORT=6379

# --- JWT ------------------------------------------------------------------
# Generate with: openssl rand -base64 32   (must decode to >= 32 bytes)
JWT_SECRET=change-me-base64-secret-at-least-32-bytes
JWT_ISSUER=incidentpulse
JWT_AUDIENCE=incidentpulse-api
JWT_ACCESS_MINUTES=15
AUTH_REFRESH_DAYS=14

# --- Seed admin (created on first boot; change the password after login) --
APP_ADMIN_USERNAME=admin
APP_ADMIN_EMAIL=admin@yourdomain.com
APP_ADMIN_PASSWORD=change-me-admin-password

# --- Email (SMTP) notifications -------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-user@gmail.com
MAIL_PASSWORD=your-smtp-app-password
APP_EMAIL_DEFAULT_RECIPIENT=oncall@yourdomain.com

# --- Webhook ingestion ----------------------------------------------------
# Shared secret external monitors send as the X-API-Key header.
# Empty disables webhook ingestion (fails closed).
WEBHOOK_API_KEY=change-me-webhook-api-key

# --- Login rate limit (optional; defaults shown) --------------------------
RATE_LIMIT_LOGIN_CAPACITY=5
RATE_LIMIT_LOGIN_REFILL_TOKENS=1
RATE_LIMIT_LOGIN_REFILL_PERIOD_MINUTES=3

# --- CORS (comma-separated origins for the React dev server / prod frontend) -
# With nginx reverse proxy on port 80, the browser origin is http://localhost
APP_CORS_ORIGINS=http://localhost,http://localhost:5173
